# Server (Express BFF)
SUPABASE_URL=
SUPABASE_KEY=
PORT=3001
OPENROUTER_API_KEY=
SITE_ORIGIN=https://arvid.work
APP_ORIGIN=https://app.arvid.work

# GitHub OAuth (separate from Supabase login — for repo access)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Linear OAuth (create at linear.app/settings/api/applications/new)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# Slack OAuth (create at api.slack.com/apps, manifest provided in docs)
# Callback URL local: http://localhost:3001/api/slack/callback
# Callback URL prod: https://arvid-api.onrender.com/api/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Frontend (Dashboard app — app.arvid.work)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE=/api

# Frontend (Marketing site — arvid.work)
VITE_APP_URL=http://localhost:5173
